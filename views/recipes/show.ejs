<!-- displays all recipes -->
<% layout('layouts/boilerplate') -%>

    <link rel="stylesheet" href="/stylesheets/card.css">
    <section>
        <div id="carouselExample" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active position-relative" data-bs-interval="3000">
                    <img src="/images/banners/recipe-banner.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption position-absolute top-50 start-50 translate-middle text-center ">
                        <h2 class="display-1 fw-bolder text-white">
                            Recipes
                        </h2>
                    </div>
                </div>
                <div class="carousel-item position-relative" data-bs-interval="5000">
                    <img src="/images/banners/recipe-banner2.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption position-absolute top-50 start-50 translate-middle text-center ">
                        <h2 class="display-1 fw-bolder text-white">
                            Recipes
                        </h2>
                    </div>
                </div>
                <div class="carousel-item position-relative" data-bs-interval="7000">
                    <img src="/images/banners/recipe-banner3.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption position-absolute top-50 start-50 translate-middle text-center ">
                        <h2 class="display-1 fw-bolder text-white">
                            Recipes
                        </h2>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container d-flex justify-content-between mb-5">
            <div>
                <button class="btn btn-outline-dark rounded-pill me-4 ">High Protein</button>
                <button class="btn btn-outline-dark rounded-pill me-4">Vegan</button>
                <button class="btn btn-outline-dark rounded-pill me-4">Vegetarian</button>
                <button class="btn btn-outline-dark rounded-pill me-4">Fish</button>
            </div>
            <div>
                <button class=" btn btn-outline-dark rounded-pill me-4 dropdown-toggle"
                    data-bs-toggle="dropdown">Filter</button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Popular</a></li>
                    <li><a class="dropdown-item" href="#">Best Seller</a></li>
                    <li><a class="dropdown-item" href="#">Chef favourite</a></li>
                </ul>
                <button class=" btn btn-outline-dark rounded-pill me-4 dropdown-toggle" data-bs-toggle="dropdown">More
                    Filter</button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Easy</a></li>
                    <li><a class="dropdown-item" href="#">Meduim</a></li>
                    <li><a class="dropdown-item" href="#">Difficult</a></li>
                </ul>
            </div>

        </div>
    </section>

    <section class="py-3">
        <div class="container">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                <% for(let recipe of recipes) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 recipe-card">
                            <!-- Image -->
                            <div class="card-img-wrapper">
                                <img src="<%= recipe.image || 'https://via.placeholder.com/400x300?text=Recipe' %>"
                                    class="card-img-top" alt="<%= recipe.title %>">
                            </div>

                            <!-- Card Body -->
                            <div class="card-body d-flex flex-column">
                                <a class="text-decoration-none link-dark" href="/recipe/detail/<%= recipe._id %>">
                                    <h5 class="card-title">
                                        <%= recipe.title %>
                                    </h5>
                                </a>
                                <p class="card-text text-muted flex-grow-1">
                                    <%= recipe.description.substring(0, 120) %>...
                                </p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        <i class="far fa-clock"></i>
                                        <%= recipe.totalTime %>
                                    </small>
                                    <small class="text-muted">
                                        by <%= recipe.author %>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>
    </section>
    <section>
        <div class="container d-flex justify-content-center mb-5">
            <div class="btn-group" role="group" aria-label="Basic radio toggle button group">
                <input type="radio" class="btn-check" name="btnradio" id="btnradio1" autocomplete="off" checked>
                <label class="btn btn-outlined" for="btnradio1">1</label>

                <input type="radio" class="btn-check" name="btnradio" id="btnradio2" autocomplete="off">
                <label class="btn btn-outlined" for="btnradio2">2</label>

                <input type="radio" class="btn-check" name="btnradio" id="btnradio3" autocomplete="off">
                <label class="btn btn-outlined" for="btnradio3">3</label>

                <input type="radio" class="btn-check" name="btnradio" id="btnradio4" autocomplete="off">
                <label class="btn btn-outlined" for="btnradio4">4</label>
            </div>
        </div>
    </section>
    <%- include('../partials/footer') %>